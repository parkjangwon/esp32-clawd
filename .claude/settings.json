{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"state\":\"typing\"}' | nc -U /tmp/clawd.sock"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"state\":\"happy\"}' | nc -U /tmp/clawd.sock"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"state\":\"notification\"}' | nc -U /tmp/clawd.sock; sleep 3; echo '{\"state\":\"idle\"}' | nc -U /tmp/clawd.sock"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"state\":\"idle\"}' | nc -U /tmp/clawd.sock"
          }
        ]
      }
    ]
  }
}
